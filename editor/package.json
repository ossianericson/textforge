{
  "name": "textforge-editor",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "files": [
    ".sidecar-build",
    "index.html",
    "postcss.config.js",
    "public",
    "scripts",
    "shared",
    "sidecar",
    "src",
    "src-tauri",
    "tailwind.config.ts",
    "templates",
    "tsconfig.json",
    "tsconfig.node.json",
    "vite.config.ts",
    "README.md"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:sidecars": "npx tsx scripts/build-sidecars.ts",
    "build:release-assets": "npm run build && npm run build:sidecars",
    "tauri": "tauri",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:ci": "vitest run --coverage --coverage.provider=v8 --coverage.reporter=text --coverage.reporter=html --coverage.reporter=cobertura",
    "check-prereqs": "npx tsx scripts/check-prereqs.ts"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-fs": "^2",
    "@tauri-apps/plugin-shell": "^2",
    "@tiptap/core": "^2",
    "@tiptap/extension-drag-handle-react": "^2",
    "@tiptap/extension-placeholder": "^2",
    "@tiptap/extension-typography": "^2",
    "@tiptap/pm": "^2",
    "@tiptap/react": "^2",
    "@tiptap/starter-kit": "^2",
    "js-yaml": "^4",
    "mermaid": "^10.9.5",
    "react": "^18",
    "react-dom": "^18",
    "reactflow": "^11",
    "zustand": "^4"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6",
    "@testing-library/react": "^14",
    "@testing-library/user-event": "^14",
    "@types/js-yaml": "^4",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^4",
    "@vitest/coverage-v8": "^3.2.4",
    "@yao-pkg/pkg": "^6.6.0",
    "autoprefixer": "^10",
    "dotenv": "^17.2.4",
    "esbuild": "^0.25.2",
    "handlebars": "^4.7.9",
    "jsdom": "^24",
    "msw": "^2.3.0",
    "postcss": "^8",
    "tailwindcss": "^3",
    "tsx": "^4",
    "typescript": "^5",
    "vite": "^6.4.1",
    "vitest": "^3.2.4",
    "zod": "^3.23.8"
  },
  "overrides": {
    "minimatch": "^10.2.1",
    "brace-expansion": "^5.0.0",
    "picomatch": "^4.0.4"
  }
}
