{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "textforge Editor",
  "version": "0.2.0",
  "identifier": "dev.textforge.editor",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build:release-assets",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "textforge Editor",
        "width": 1440,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 620,
        "resizable": true,
        "devtools": false,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "script-src": "'self' 'wasm-unsafe-eval'",
        "style-src": "'self' 'unsafe-inline'",
        "img-src": "'self' data: blob:",
        "font-src": "'self' data:",
        "connect-src": "'self' https://*.openai.azure.com https://api.openai.com https://*.cognitiveservices.azure.com",
        "frame-src": "'self' blob:",
        "object-src": "'none'",
        "base-uri": "'self'",
        "form-action": "'self'"
      },
      "dangerousDisableAssetCspModification": false
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "binaries/*",
      "../../core/badges.yml",
      "../../renderers/html/default-v1/template.html",
      "../../renderers/html/default-v2/template.html"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
