# Decision Tree Builder — Environment Configuration
# Copy this file to .env and customize as needed.
# All values below are defaults — override only what you need.

# Directory containing decision tree spec folders (each with a spec.md)
# DTB_DECISION_TREES_DIR=decision-trees/

# Directory for compiled HTML output
# DTB_OUTPUT_DIR=output/

# Path to the Handlebars HTML template
# DTB_TEMPLATE_PATH=core/base-template.html

# Path to the badge color definitions
# DTB_BADGE_PATH=core/badges.yml

# Logging: debug | info | warn | error (default: info)
# LOG_LEVEL=info

# Log format: text (default) or json
# LOG_FORMAT=text
# LOG_JSON=false
